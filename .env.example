# ==========================================
# GLPI Configuration
# ==========================================
GLPI_URL=http://your-glpi-host/apirest.php
GLPI_APP_TOKEN=your-app-token-here
GLPI_USER_TOKEN=your-user-token-here
# Alternative authentication:
# GLPI_USERNAME=your-username
# GLPI_PASSWORD=your-password

# ==========================================
# MCP Server Configuration
# ==========================================
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ==========================================
# Proxmox Network Configuration (LXC IPs)
# ==========================================
# IP interna fija para este hub en la red Proxmox
HUB_INTERNAL_HOST=192.168.90.98

# IP de la VPS/GLPI en la red Proxmox
GLPI_INTERNAL_HOST=10.0.0.20

# IP del Hermes Agent en la red Proxmox
HERMES_AGENT_INTERNAL_HOST=10.0.0.5

# Subnet de la red interna Proxmox
PROXMOX_NETWORK_SUBNET=10.0.0.0/24

# ==========================================
# Hermes Agent (opcional - para callbacks)
# ==========================================
HERMES_AGENT_URL=http://10.0.0.5:9090

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
